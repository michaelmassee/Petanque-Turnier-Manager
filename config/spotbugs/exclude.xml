<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs Exclude-Filter — Block B2 aus architektur-robust-analyse.md.

    Initial leer; ein erster Lauf (./gradlew spotbugsMain) erzeugt
    build/reports/spotbugs/main.xml. Dieser kann als Baseline-Excludefilter
    übernommen werden, damit künftig nur NEUE Findings den Build brechen.
    Solange ignoreFailures = true ist, dient dieser Filter nur als Whitelist
    bekannter False-Positives.

    Format-Doku: https://spotbugs.readthedocs.io/en/latest/filter.html
-->
<FindBugsFilter>

    <!--
        WebServerInstanz/CompositeViewInstanz: getCachedInitJson() und
        getKonfiguration() sind nicht synchronized, die zugehörigen Setter schon.
        Die gelesenen Felder (cachedInitJson, konfiguration) sind aber bereits
        volatile — Sichtbarkeit ist garantiert, kein Sync-Bedarf für reine Reads.
        Die Setter-Synchronisation schützt nur Compound-Updates (Cache + SSE-Push).
        → False Positive für diese 4 Getter.
    -->
    <Match>
        <Or>
            <Class name="de.petanqueturniermanager.webserver.WebServerInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.CompositeViewInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.TurnierStartseiteWebServerInstanz"/>
        </Or>
        <Or>
            <Method name="getCachedInitJson"/>
            <Method name="getKonfiguration"/>
        </Or>
        <Bug pattern="UG_SYNC_SET_UNSYNC_GET"/>
    </Match>

    <!--
        TimerManager.get(): SpotBugs meldet SING_SINGLETON_GETTER_NOT_SYNCHRONIZED.
        Das Feld 'instanz' ist aber bereits 'volatile' (siehe TimerManager.java:37);
        ein Lese-Zugriff auf eine volatile-Referenz braucht keine Synchronisation.
        Double-Checked-Locking in init()/dispose() ist korrekt umgesetzt.
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.timer.TimerManager"/>
        <Method name="get"/>
        <Bug pattern="SING_SINGLETON_GETTER_NOT_SYNCHRONIZED"/>
    </Match>

    <!--
        CT_CONSTRUCTOR_THROW: SpotBugs warnt vor Konstruktoren, die Exceptions werfen,
        weil ein Angreifer per Finalizer-Attack auf einen halb-initialisierten Zustand
        zugreifen koennte. Diese Klassen sind weder Cloneable noch Serializable und
        haben keine ueberschriebenen finalize()-Methoden. Ab Java 9 ist der Finalizer-
        Attack durch das Sicherheitsmodell ohnehin entscheidend entschaerft, und die
        betroffenen Konstruktoren werden ausschliesslich aus Plugin-internem Code mit
        kontrollierten Aufrufern verwendet (kein UNO-Zugriff von aussen).
        → Bewusst akzeptiert, kein Risiko in diesem Kontext.
    -->
    <Match>
        <Or>
            <Class name="de.petanqueturniermanager.comp.GlobalProperties"/>
            <Class name="de.petanqueturniermanager.helper.DocumentPropertiesHelper"/>
            <Class name="de.petanqueturniermanager.helper.sheet.RanglisteGeradeUngeradeFormatHelper"/>
            <Class name="de.petanqueturniermanager.konfigdialog.dialog.element.UIElement"/>
            <Class name="de.petanqueturniermanager.timer.TimerWebServerInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.CompositeViewInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.WebServerInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.TurnierStartseiteWebServerInstanz"/>
            <Class name="de.petanqueturniermanager.webserver.WebserverRegieServerInstanz"/>
            <Class name="de.petanqueturniermanager.helper.msgbox.ProcessBox"/>
        </Or>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!--
        EQ_COMPARETO_USE_OBJECT_EQUALS: SpielerEndranglisteErgebnis, SpielerSpieltagErgebnis und
        TripTeteTeamErgebnis ueberschreiben compareTo() (Rangordnung nach Spielen/Punkten), aber nicht equals().
        Das ist beabsichtigt: equals() bleibt identity-basiert (Object), weil zwei
        Ergebnisinstanzen mit identischen Statistik-Feldern semantisch nicht "gleich" sind —
        sie gehoeren zu unterschiedlichen Spielern oder Spieltagen. compareTo() definiert
        nur die Sortierung in der Rangliste, keine Aequivalenzrelation.
        → Bewusst akzeptierte Inkonsistenz mit Comparable-Empfehlung.
    -->
    <Match>
        <Or>
            <Class name="de.petanqueturniermanager.supermelee.ergebnis.SpielerEndranglisteErgebnis"/>
            <Class name="de.petanqueturniermanager.supermelee.ergebnis.SpielerSpieltagErgebnis"/>
            <Class name="de.petanqueturniermanager.algorithmen.triptete.TripTeteTeamErgebnis"/>
        </Or>
        <Bug pattern="EQ_COMPARETO_USE_OBJECT_EQUALS"/>
    </Match>

    <!--
        ProtocolHandler.SHARED_CONTEXT: SpotBugs ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD.
        Bewusste Cross-Instance-State: ProtocolHandler wird von LO einmal pro Frame
        instanziiert; die statische isEnabled()-Pruefung (XStatusListener) braucht den
        XComponentContext aus irgendeiner Instanz – das Feld ist volatile und nur als
        spaet initialisierter Bootstrap-Verweis gedacht.
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.comp.ProtocolHandler"/>
        <Field name="SHARED_CONTEXT"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>

    <!--
        ProtocolHandler.isEnabled(): REC_CATCH_EXCEPTION ist beabsichtigt.
        Diese Methode entscheidet die Aktivierung jedes Toolbar-Eintrags und darf
        unter keinen Umstaenden propagieren – ein einzelner UNO-Fehler beim Lesen
        der Properties wuerde sonst die ganze Toolbar lahmlegen. Catch-all → false.
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.comp.ProtocolHandler"/>
        <Method name="isEnabled"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

    <!--
        ============================================================
        MALICIOUS_CODE-Kategorie pauschal ausgeschlossen (154 Findings)
        ============================================================
        Betroffene Pattern: EI_EXPOSE_REP, EI_EXPOSE_REP2, MS_EXPOSE_REP,
        MS_MUTABLE_COLLECTION, MS_MUTABLE_COLLECTION_PKGPROTECT, MS_PKGPROTECT.

        Begruendung:
        Diese Pattern warnen vor fehlender defensiver Kopie/Immutable-Wrapping
        an API-Grenzen. Sie sind fuer Bibliotheken mit unbekannten/hostile
        Aufrufern gedacht. Petanque-Turnier-Manager ist eine LibreOffice-Calc-
        Extension mit ausschliesslich plugin-internem Aufrufverkehr:

        1. UNO-API-Referenzen (XSpreadsheetDocument, XComponentContext, XSheet,
           XControl, XToolkit, ...) sind Remote-Proxies auf LO-interne Objekte –
           defensives Kopieren ist weder moeglich noch sinnvoll.
        2. Das Domain-Modell (Team, Spieler, TeamPaarung, Direktvergleich,
           SpielerSpielrundeErgebnis, KaskadenKoRunde, ...) teilt absichtlich
           Zustand zwischen Algorithmen und Sheet-Schreibern – Kopien wuerden
           Querverweise (gegner, warImTeamMit, etc.) zerstoeren.
        3. KONFIG_PROPERTIES-Listen in *PropertiesSpalte werden in statischen
           Init-Bloecken aufgebaut und dann als Read-Only-Registry verwendet;
           Immutable-Wrapping wuerde das Add-on-Property-Schema erschweren ohne
           realen Sicherheitsgewinn.
        4. Singleton-Getter (TimerManager.get, WebServerManager.get, ProcessBox,
           BlattschutzManager, ...) geben absichtlich die Singleton-Instanz
           zurueck – das ist das Wesen des Patterns.

        Statt 150+ Einzel-Excludes oder grossflaechiger Defensiv-Kopier-Aktion
        wird die Kategorie hier dokumentiert akzeptiert. Wenn die Architektur
        spaeter erodiert (z.B. echtes Public-API-Modul), kann dieser Pauschal-
        Exclude wieder aufgeloest werden.
    -->
    <Match>
        <Bug category="MALICIOUS_CODE"/>
    </Match>

    <!--
        SpielerDbConnection: embedded HSQLDB im User-Homeverzeichnis. Der Default
        "SA"/"" ist HSQLDB-Standard für embedded mode (keine Auth, lokale Datei).
        Ein "echtes" Passwort wäre Sicherheitstheater — die Datei ist ohnehin
        per Filesystem-Permissions geschützt, und das Passwort müsste irgendwo
        unverschlüsselt mitliegen.
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.spielerdb.SpielerDbConnection"/>
        <Bug pattern="DMI_EMPTY_DB_PASSWORD"/>
    </Match>

    <!--
        SpielerDbConnection.close() resettet das statische INSTANCE-Feld auf null,
        damit ein erneutes getInstance() eine frische Connection aufbaut. Der
        Schreibzugriff von einer Instanzmethode aus ist beabsichtigter Singleton-
        Lifecycle (Reset im Tests-Hook).
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.spielerdb.SpielerDbConnection"/>
        <Method name="close"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>

    <!--
        Gson-DTOs in GithubReleaseClient (innere Klassen ReleaseDto, AssetDto):
        Felder werden von Gson per Reflection beim JSON-Parsing gesetzt. SpotBugs
        sieht keinen expliziten Java-Write und meldet UWF_UNWRITTEN_FIELD.
        → False Positive, kein Bug.
    -->
    <Match>
        <Or>
            <Class name="de.petanqueturniermanager.comp.newrelease.GithubReleaseClient$ReleaseDto"/>
            <Class name="de.petanqueturniermanager.comp.newrelease.GithubReleaseClient$AssetDto"/>
        </Or>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>

    <!--
        ReleaseUpdateService nutzt ein Singleton-Pattern mit init()/get()/dispose(),
        hat aber einen package-private Konstruktor für Tests (Injection von Fake-Cache
        und Fake-Client). Der echte Produktivpfad geht ausschliesslich über init().
        → False Positive.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.comp.newrelease.ReleaseUpdateService"/>
        <Bug pattern="SING_SINGLETON_HAS_NONPRIVATE_CONSTRUCTOR"/>
    </Match>

    <!--
        PdfHtmlDokument.erstelle(): VA_FORMAT_STRING_USES_NEWLINE
        Die Methode verwendet ein Java-Textblock mit .formatted(), das LF-Zeichen (\n)
        enthaelt. SpotBugs empfiehlt %n fuer plattformunabhaengige Zeilenenden — das ist
        fuer Console-/Datei-Text korrekt. Hier wird jedoch HTML erzeugt, wo LF (\n)
        der einzig richtige Zeilenumbruch ist; %n wuerde auf Windows CRLF generieren,
        was valid ist, aber unnoetige Diff-Noise produziert.
        → False Positive: HTML-Erzeugung, kein Plattform-Zeilenende-Problem.
    -->
    <Match>
        <Or>
            <Class name="de.petanqueturniermanager.helper.upload.PdfHtmlDokument"/>
            <Class name="de.petanqueturniermanager.helper.upload.ExportFooterHtml"/>
            <Class name="de.petanqueturniermanager.webserver.WebserverRegieServerInstanz"/>
        </Or>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <!--
        ExportHtmlSeite.PTM_EXPORT_LOGO_DATA_URI: HSC_HUGE_SHARED_STRING_CONSTANT.
        Das Feld ist ein eingebettetes PNG-Logo als base64-Data-URI (data:image/png;
        base64,...). Es absichtlich als String-Konstante zu halten, ist genau der
        Zweck: das Logo wird ohne externe Datei direkt in den HTML-/PDF-Export
        eingebettet. SpotBugs warnt nur vor der reinen Groesse — hier bewusst
        akzeptiert, kein Bug.
        → False Positive: bewusst eingebettetes Asset.
    -->
    <Match>
        <Class name="de.petanqueturniermanager.helper.upload.ExportHtmlSeite"/>
        <Field name="PTM_EXPORT_LOGO_DATA_URI"/>
        <Bug pattern="HSC_HUGE_SHARED_STRING_CONSTANT"/>
    </Match>

</FindBugsFilter>
